{
  "name": "nebuloud",
  "version": "0.0.1",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --host 0.0.0.0",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "public": "ng build && cd dist/nebuloud/browser && cp index.html 404.html && gh-pages -d . --cname nebuloud.zvalentin.ru",
    "test": "ng test",
    "serve:ssr:nebuloud": "node dist/nebuloud/server/server.mjs",
    "format": "prettier . --write"
  },
  "private": true,
  "packageManager": "npm@11.10.0",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/platform-server": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@angular/ssr": "^21.2.0",
    "@angular/youtube-player": "^21.2.0",
    "@twogate/ngx-photo-gallery": "^1.8.1",
    "copy-text-to-clipboard": "^3.2.2",
    "cyrillic-to-translit-js": "^3.2.1",
    "express": "^5.1.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.0",
    "@angular/cli": "^21.2.0",
    "@angular/compiler-cli": "^21.2.0",
    "@types/express": "^5.0.1",
    "@types/node": "^25.3.3",
    "gh-pages": "^6.3.0",
    "prettier": "3.8.1",
    "typescript": "~5.9.2"
  }
}
